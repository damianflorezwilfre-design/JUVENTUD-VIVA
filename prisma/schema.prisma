generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("SUPER_ADMIN")
  modules   String   @default("") // Comma separated list of allowed modules
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  requests  EditRequest[]
}

model EditRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  action       String   // "EDIT" or "DELETE"
  modelName    String   // "News", "Gallery", "Document", etc.
  recordId     String   // ID of the record to edit or delete
  proposedData String?  // JSON string of the proposed changes (null for DELETE)
  status       String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Program {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  fileUrl     String
  type        String   // pdf, doc, xls
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Gallery {
  id        String   @id @default(cuid())
  title     String?
  url       String
  type      String   // image, video
  createdAt DateTime @default(now())
}

model Institution {
  id        String   @id @default("singleton")
  aboutUs       String?
  mission       String?
  vision        String?
  address       String?
  phone         String?
  email         String?
  facebook      String?
  instagram     String?
  twitter       String?
  feature1Title String?
  feature1Desc  String?
  feature2Title String?
  feature2Desc  String?
  feature3Title String?
  feature3Desc  String?
  publicBackground String? 
  donationLink  String? // Modals info or direct link
  bankInfo      String? // e.g. "Bancolombia: 1234567"
  stat1Value    String? // e.g. "500+"
  stat1Label    String? // e.g. "Jóvenes Impactados"
  stat2Value    String?
  stat2Label    String?
  stat3Value    String?
  stat3Label    String?
  transparency1Title String?
  transparency1Desc  String?
  transparency2Title String?
  transparency2Desc  String?
  transparency3Title String?
  transparency3Desc  String?
  calcKitCost        Float?   @default(50000)
  calcMealCost       Float?   @default(15000)
  whatsappApiKey     String?
  whatsappGroupPhone String?
  updatedAt     DateTime @updatedAt
}

model Alliance {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  website   String?
  createdAt DateTime @default(now())
}

model RoadmapAction {
  id          String   @id @default(cuid())
  title       String
  description String
  date        String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model FinanceRecord {
  id            String   @id @default(cuid())
  type          String
  description   String
  amount        Float
  donorDocument String?
  date          DateTime @default(now())
  proofUrl      String?
  createdAt     DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Analytics {
  id           String   @id @default(cuid())
  date         DateTime @unique @default(now()) @db.Date
  portalViews  Int      @default(0)
  fbClicks     Int      @default(0)
  igClicks     Int      @default(0)
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?  @db.Text
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrgNode {
  id        String    @id @default(cuid())
  title     String
  name      String?
  parentId  String?
  parent    OrgNode?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  OrgNode[] @relation("OrgHierarchy")
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Volunteer {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String
  skills       String?  @db.Text
  availability String?
  points       Int      @default(0)
  imageUrl     String?
  isContacted  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  quote     String   @db.Text
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  date        DateTime
  location    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sponsorship {
  id            String   @id @default(cuid())
  title         String
  description   String   @db.Text
  goalAmount    Float?
  currentAmount Float    @default(0)
  imageUrl      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MapPin {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  lat         Float
  lng         Float
  location    String
  imageUrl    String?
  date        DateTime @default(now())
}

model Opportunity {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String   @db.Text
  type        String   // "BECA" or "EMPLEO"
  link        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model WallMessage {
  id          String   @id @default(cuid())
  name        String
  message     String   @db.Text
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
}
